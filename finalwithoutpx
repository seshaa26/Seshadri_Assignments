import os
import csv
import re

# ====== CONFIGURE THESE PATHS ======

SOURCE_DIR = r'\\resNP.sysNP.shared.fortis\Files\C\Global\_ApplicationData\MTS-PXRS\se-xf-traceability\Monitoring\KAFKA'
MTS_refcsv = './MTSref.csv'
OUT_MATCHES = r"C:\Users\f30643\AppData\Local\Programs\Python\Python310\feed.txt"
LOG_CSV = './logs/logs.csv'

# ===================================

def load_keys_from_csv(csv_path):
    keys = []
    with open(csv_path, "r", encoding="utf-8", errors="ignore", newline="") as f:
        reader = csv.reader(f)
        for row in reader:
            if not row:
                continue
            key = row[0].strip()
            if key:
                keys.append(key)
    return keys

def main():
    keys = load_keys_from_csv(MTS_refcsv)
    if not keys:
        print("No keys loaded from CSV; please check keys.csv.")
        return

    # Prebuild regex patterns for exact key
    patterns = {key: re.compile(re.escape(key)) for key in keys}

    # Stats per key
    stats = {
        key: {"found": False, "files": set(), "lines": 0}
        for key in keys
    }

    # Search and write matching lines (PRESERVE exact source format)
    with open(OUT_MATCHES, "w", encoding="utf-8", errors="ignore") as out_f:
        out_f.write("filename\tkey\tline\n")
        
        for root, _, files in os.walk(SOURCE_DIR):
            for name in files:
                if not name.lower().endswith(".txt"):
                    continue

                file_path = os.path.join(root, name)

                try:
                    with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                        for line_num, line in enumerate(f, 1):
                            # line includes trailing from source file
                            for key, patt in patterns.items():
                                if patt.search(line):
                                    # Write: filename\tkey\tORIGINAL LINE EXACTLY AS SOURCE
                                    out_f.write(f"{file_path}\t{key}\t{line.rstrip()}")
                                    stats[key]["found"] = True
                                    stats[key]["files"].add(file_path)
                                    stats[key]["lines"] += 1
                                    break  # one key per line (optimize)
                except Exception as e:
                    print(f"Error reading {file_path}: {e}")

    # Write log CSV
    with open(LOG_CSV, "w", newline="", encoding="utf-8") as log_f:
        writer = csv.writer(log_f)
        writer.writerow(["key", "found", "files_count", "lines_count"])
        for key, info in stats.items():
            writer.writerow([
                key,
                "YES" if info["found"] else "NO",
                len(info["files"]),
                info["lines"],
            ])
    
    print(f"Search complete. Matches: {OUT_MATCHES}, Log: {LOG_CSV}")

if __name__ == "__main__":
    main()
